# Database Configuration
# Used by both PHP API and Node.js scrape engine
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=wayrus

# Scrape Engine (Node.js)
ENGINE_PORT=3001

# Frontend API Configuration
# Used by React components to call the PHP API
VITE_API_URL=https://wayrus.co.ke/api

# Optional: Upload directory for screenshots/files
UPLOAD_DIR=/home/wayrusc1/public_html/uploads/screenshots/

# Screenshot Service (for portfolio preview capture)
# Get your API key from https://urlbox.io
SCREENSHOT_SERVICE_API_KEY=your_urlbox_api_key_here
